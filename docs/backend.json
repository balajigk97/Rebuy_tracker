
{
  "entities": {
    "Player": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Player",
      "type": "object",
      "description": "Represents a player in the poker game.",
      "properties": {
        "name": {
          "type": "string",
          "description": "The player's chosen name."
        },
        "blackCoins": {
          "type": "number",
          "description": "The number of black coins the player has at the end of the game."
        },
        "createdAt": {
          "type": "object",
          "description": "The timestamp when the player was created."
        },
        "rebuyTimestamps": {
          "type": "array",
          "description": "An array of timestamps for each buy-in and re-buy.",
          "items": {
            "type": "object"
          }
        },
        "hasPendingRebuyRequest": {
          "type": "boolean",
          "description": "True if the player has requested a rebuy and is waiting for dealer approval."
        }
      },
      "required": [
        "name",
        "blackCoins",
        "createdAt",
        "rebuyTimestamps",
        "hasPendingRebuyRequest"
      ]
    },
    "Game": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Game",
      "type": "object",
      "description": "Represents a historical record of a completed game.",
      "properties": {
        "endedAt": {
          "type": "object",
          "description": "The timestamp when the game was completed."
        },
        "players": {
          "type": "array",
          "description": "A snapshot of the players and their results from the game.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "buyIns": {
                "type": "number"
              },
              "blackCoins": {
                "type": "number"
              },
              "endCount": {
                "type": "number"
              }
            },
            "required": ["name", "buyIns", "blackCoins", "endCount"]
          }
        }
      },
      "required": ["endedAt", "players"]
    }
  },
  "auth": {
    "providers": [
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/players/{playerId}",
        "definition": {
          "entityName": "Player",
          "schema": {
            "$ref": "#/backend/entities/Player"
          },
          "description": "Stores information for each player in the game.",
          "params": [
            {
              "name": "playerId",
              "description": "The unique ID of the player document."
            }
          ]
        }
      },
      {
        "path": "/games/{gameId}",
        "definition": {
            "entityName": "Game",
            "schema": {
                "$ref": "#/backend/entities/Game"
            },
            "description": "Stores historical records of completed games."
        }
      }
    ]
  }
}
