/**
 * @fileoverview Firestore Security Rules for the poker game application.
 *
 * Core Philosophy:
 * This ruleset prioritizes security and data integrity, focusing on controlling
 * access to player data. It explicitly denies unauthorized access to prevent
 * malicious data manipulation.
 *
 * Data Structure:
 * - All player data is stored in the `/players/{playerId}` collection.
 *
 * Key Security Decisions:
 * - Players data is publicly readable.
 * - Players data can only be created, updated and deleted by authenticated users.
 *
 * Denormalization for Authorization:
 *   N/A - No denormalization is used in this ruleset.
 *
 * Structural Segregation:
 *   N/A - No structural segregation is used in this ruleset.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages access to individual player documents.
     * @path /players/{playerId}
     * @allow (get, list): Any user can read data about players.
     * @allow (create): Authenticated users can create new players.
     * @allow (update, delete): Authenticated users can update or delete their own player data.
     * @deny (create, update, delete): Unauthenticated users cannot create, update or delete player data.
     * @principle Enforces authentication for writing operations and makes the player data publicly readable.
     */
    match /players/{playerId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    // Helper function to determine if a user is signed in.
    function isSignedIn() {
      return request.auth != null;
    }
  }
}