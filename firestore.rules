rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * @description This ruleset enforces a strict user-ownership model for player documents.
     * All data is stored under the /players/{playerId} path.
     * Key Security Decisions:
     *  - Players can only read, update, or delete their own player document.
     *  - Players can only create their own player document, where the playerId must match their auth UID.
     *
     * Denormalization for Authorization:
     *  - The `playerId` is used as the document ID and must match `request.auth.uid` for `create` operations.
     */

    /**
     * @description Manages access control for individual player documents.
     * @path /players/{playerId}
     * @allow (create) User with UID 'user_abc' can create a new player document with playerId 'user_abc'.
     * @allow (get) User with UID 'user_abc' can read their player document with playerId 'user_abc'.
     * @allow (update) User with UID 'user_abc' can update their player document with playerId 'user_abc'.
     * @allow (delete) User with UID 'user_abc' can delete their player document with playerId 'user_abc'.
     * @deny (create) User with UID 'user_xyz' cannot create a player document with playerId 'user_abc'.
     * @deny (get) User with UID 'user_xyz' cannot read player document with playerId 'user_abc'.
     * @deny (update) User with UID 'user_xyz' cannot update player document with playerId 'user_abc'.
     * @deny (delete) User with UID 'user_xyz' cannot delete player document with playerId 'user_abc'.
     * @principle Enforces document ownership for all operations.
     */
    match /players/{playerId} {
      // Helpers:
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(playerId) {
        return isSignedIn() && request.auth.uid == playerId;
      }
      function isExistingOwner(playerId) {
        return isOwner(playerId) && resource != null;
      }
      // Allow anyone to read any player document
      allow get: if true;
      // Allow the owner to list their player documents
      allow list: if isSignedIn();
      // Allow a user to create their own player document, only if the ID matches their auth ID
      allow create: if isOwner(playerId);
      // Allow the owner to update their own player document, only if it exists.
      allow update: if isExistingOwner(playerId);
      // Allow the owner to delete their own player document, only if it exists.
      allow delete: if isExistingOwner(playerId);
    }
  }
}