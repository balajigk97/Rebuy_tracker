/**
 * @fileoverview Firestore Security Rules for the Poker Game application.
 *
 * Core Philosophy:
 * This ruleset prioritizes simplicity, security and data access control by leveraging the Firebase Authentication state (`request.auth`).
 * It focuses on securing read and write access to a public collection of `players`. All users, including unauthenticated ones, can read `players` collection, but only authenticated users can create, update or delete player information.
 *
 * Data Structure:
 * The Firestore database contains one top-level collection:
 * - `/players/{playerId}`: Stores individual player profiles for the live game.
 *
 * Key Security Decisions:
 * - Public Read Access: All users, including unauthenticated users, can read all documents in the `players` collection.
 * - Authenticated Writes: Only authenticated users can create, update, and delete documents.
 *
 * Denormalization for Authorization:
 * - The `Player` documents are assumed to contain all the necessary information for authorization.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows anyone to read player data, but only authenticated users to write.
     * @path /players/{playerId}
     * @allow (read): Anyone can read player data.
     * @allow (write): Authenticated user can write player data.
     */
    match /players/{playerId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ---- Helper functions ----

    /**
     * @description Checks if the user is signed in.
     * @return {bool} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }
  }
}
