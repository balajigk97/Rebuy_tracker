/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for player data.
 *
 * Data Structure:
 * All player data is stored in the `/players/{playerId}` collection.
 *
 * Key Security Decisions:
 * - Players can only read, create, update, and delete their own player documents.
 * - Data shape is not validated to allow for rapid iteration.
 *
 * Denormalization for Authorization:
 *  - The `playerId` is used to match against the `request.auth.uid` for authorization.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages access to individual player documents.
     * @path /players/{playerId}
     * @allow (get) User can read their own player document.
     * @allow (create) User can create their own player document if the playerId matches their auth UID.
     * @allow (update) User can update their own player document.
     * @allow (delete) User can delete their own player document.
     * @deny (get) User cannot read another user's player document.
     * @deny (create) User cannot create a player document with a playerId that does not match their auth UID.
     * @deny (update) User cannot update another user's player document.
     * @deny (delete) User cannot delete another user's player document.
     * @principle Enforces document ownership for all operations.
     */
    match /players/{playerId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(playerId) {
        return request.auth.uid == playerId;
      }

      function isExistingOwner(playerId) {
        return isOwner(playerId) && resource != null;
      }

      allow get: if isSignedIn() && isOwner(playerId);
      allow list: if false;

      allow create: if isSignedIn() && isOwner(playerId);
      allow update: if isSignedIn() && isExistingOwner(playerId);
      allow delete: if isSignedIn() && isExistingOwner(playerId);
    }
  }
}