/**
 * @file Firestore Security Rules
 * @description This ruleset is in **Prototyping Mode**. It prioritizes strong authorization
 *   while relaxing data validation to enable rapid development. Data validation is limited
 *   to fields crucial for authorization and relational integrity.
 *
 * Core Philosophy:
 *   - All data access is predicated on user authentication. Anonymous access is not permitted.
 *   - Where applicable, ownership-based access control is enforced. Users can only
 *     modify or delete resources they own.
 *   - Data consistency is maintained by validating the integrity of relational fields
 *     during `create` operations and enforcing immutability on these fields during `update`
 *     operations.
 *
 * Data Structure:
 *   - The Firestore database contains a `players` collection at the root.
 *
 * Key Security Decisions:
 *   - Data shape is not strictly validated. This is a prototyping tradeoff.
 *   - Users cannot list other users.
 *
 * Denormalization for Authorization:
 *   - The 'Player' entity does not currently have a means of authorization.
 *     In order to proceed a `dealerId` or `ownerId` field should be added to the `Player` entity.
 *     This will allow us to perform an authorization check.
 *
 * Structural Segregation:
 *   - There is no need to segregate the data at this time.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * @description Controls access to the 'players' collection.
     *   In the current schema, the 'Player' entity lacks an 'ownerId' or 'dealerId' field.
     *   Without such a field, we cannot securely restrict write access to authorized users.
     *   For now, write access is disabled to prevent unauthorized data modification.
     *   Read access is open to all authenticated users.
     * @path /players/{playerId}
     * @allow (get, list) User is signed in.
     * @deny (create, update, delete) Always. No owner ID to authorize against.
     * @principle Requires an 'ownerId' or 'dealerId' field in the 'Player' entity for secure write access.
     */
    match /players/{playerId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    // Define the isSignedIn function
    function isSignedIn() {
      return request.auth != null;
    }
  }
}