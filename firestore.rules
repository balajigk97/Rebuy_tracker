/**
 * @file Firestore Security Rules
 * @version 2
 *
 * @description
 * This ruleset enforces a strict user-ownership model for all data. Each user (dealer)
 * has their own private data tree under `/users/{userId}`.  This data is only
 * accessible to the user with the matching `uid`.
 *
 * Data Structure:
 * All data is nested under `/users/{userId}`, providing a clear separation
 * between users' data.
 *
 * Key Security Decisions:
 * - User listing is explicitly denied to prevent unauthorized enumeration of user accounts.
 * - All write operations are restricted to the authenticated user and must
 *   match the `userId` in the path.
 * - In this initial prototyping phase, the data schema itself is not strictly enforced,
 *   allowing for flexible data shapes.  However, the rules do validate that the `uid`
 *   in the document matches the path.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Restricts access to the /users collection to ensure that
     *              users cannot be listed. This is to prevent unauthorized
     *              enumeration of user accounts.
     * @path /databases/{database}/documents/users
     * @allow None
     * @deny (list) Any attempt to list users.
     * @principle Prevents user enumeration.
     */
    match /users {
      // Disable listing all users.
      allow list: if false;
    }

    /**
     * @description Controls access to individual user documents. Only the
     *              authenticated user with a matching `uid` can read, update,
     *              or delete their own document.  Allows self-creation.
     * @path /databases/{database}/documents/users/{userId}
     * @allow (get) Authenticated user 'user_abc' can read their own user document at /users/user_abc.
     * @allow (create) Authenticated user 'user_abc' can create their own user document at /users/user_abc.
     * @allow (update) Authenticated user 'user_abc' can update their own user document at /users/user_abc.
     * @allow (delete) Authenticated user 'user_abc' can delete their own user document at /users/user_abc.
     * @deny (get) Authenticated user 'user_xyz' cannot read user document at /users/user_abc.
     * @deny (create) Unauthenticated user cannot create a user document.
     * @deny (update) Authenticated user 'user_xyz' cannot update user document at /users/user_abc.
     * @deny (delete) Authenticated user 'user_xyz' cannot delete user document at /users/user_abc.
     * @principle Enforces user-ownership.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isSignedIn() && isOwner(userId) && existsAfter(/databases/$(database)/documents/users/$(userId));
      }

      allow get: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }
  }
}