/**
 * @fileoverview Firestore Security Rules for the poker game application.
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model where each player document is owned by the anonymous user that created it.
 *
 * Data Structure:
 * All player data is stored in the `/players/{playerId}` collection.
 *
 * Key Security Decisions:
 *  - Players can only read and write their own player documents, using the anonymous authentication ID as the owner ID.
 *  - Listing of players is not allowed.
 *
 * Denormalization for Authorization:
 *  - The `playerId` is used as the owner ID, matching the Firebase Auth UID for simplified rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages access to individual player documents.
     * @path /players/{playerId}
     * @allow (create) - An anonymous user can create their own player document.
     * @allow (get, update, delete) - An anonymous user can only access their own player document if it exists.
     * @deny (create) - An anonymous user cannot create a document with a `playerId` that does not match their own auth ID.
     * @deny (update, delete) - An anonymous user cannot modify or delete a player document that does not belong to them, or if the document doesn't exist.
     * @principle Enforces document ownership for all operations.
     */
    match /players/{playerId} {
      // Helpers
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(playerId) {
        return request.auth.uid == playerId;
      }

      function isExistingOwner(playerId) {
        return isSignedIn() && isOwner(playerId) && resource != null;
      }

      // Read Permissions
      allow get: if true;
      allow list: if false;

      // Write Permissions
      allow create: if isSignedIn() && isOwner(playerId);
      allow update: if isExistingOwner(playerId);
      allow delete: if isExistingOwner(playerId);
    }
  }
}