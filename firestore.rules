/**
 * @fileoverview Firestore Security Rules for Rebuy Tracker.
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model for the 'users' collection,
 * ensuring that only the authenticated user can read and write their own data.
 * Players data is globally writeable, but it should not be.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information.
 * - /players/{playerId}: Stores player data.
 *
 * Key Security Decisions:
 * - User listing is disallowed.
 * - Players listing is public.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces user-ownership for the 'users' collection. Only the authenticated user can read and write their own profile.
     * @path /databases/{database}/documents/users/{userId}
     * @allow (create) User 'test' with uid 'test' can create their own profile document.
     * @deny (create) User 'test' cannot create a profile document with a different userId.
     * @allow (get) User 'test' with uid 'test' can read their own profile document.
     * @deny (get) User 'test' cannot read another user's profile document.
     * @allow (update) User 'test' with uid 'test' can update their own profile document.
     * @deny (update) User 'test' cannot update another user's profile document.
     * @allow (delete) User 'test' with uid 'test' can delete their own profile document.
     * @deny (delete) User 'test' cannot delete another user's profile document.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      // Read Permissions
      allow get: if isOwner(userId);
      allow list: if false; // User listing is not permitted

      // Write Permissions
      allow create: if isOwner(userId) && request.resource.data.uid == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.uid == resource.data.uid;
      allow delete: if isExistingOwner(userId);
    }

        /**
     * @description Allows public read access and write access.
     * @path /databases/{database}/documents/players/{playerId}
     * @allow (get) Any user can read any players document.
     * @allow (list) Any user can list players documents.
     * @allow (create) Any user can create a players document.
     * @allow (update) Any user can update a players document.
     * @allow (delete) Any user can delete a players document.
     * @principle Allows any user to read and write player data
     */
    match /players/{playerId} {
      allow get, list: if true;
      // CRITICAL: The 'Player' entity is missing an 'ownerId' or 'authorId' field.
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }
  }
}