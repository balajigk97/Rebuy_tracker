/**
 * @fileoverview Firestore Security Rules for the poker game application.
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model where each player document is owned by the anonymous user that created it.
 * Players can only read, update, or delete their own player documents.
 *
 * Data Structure:
 * All player data is stored in the `/players/{playerId}` collection.
 *
 * Key Security Decisions:
 *  - Players can only manage their own data.
 *  - Data shape validation is relaxed to allow for prototyping.
 *
 * Denormalization for Authorization:
 *  - The `playerId` is used to match the `request.auth.uid` for ownership checks, avoiding extra reads.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to individual player documents.
     * @path /players/{playerId}
     * @allow (get) User can read any player document.
     * @allow (list) User can list any player document.
     * @allow (create) User with a matching playerId can create a player document.
     * @allow (update) User with a matching playerId can update a player document.
     * @allow (delete) User with a matching playerId can delete a player document.
     * @deny (create) User without a matching playerId cannot create a player document.
     * @deny (update) User without a matching playerId cannot update a player document.
     * @deny (delete) User without a matching playerId cannot delete a player document.
     * @principle Enforces document ownership for writes, allows public reads.
     */
    match /players/{playerId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.auth.uid == playerId;
      allow update: if isSignedIn() && isExistingOwner(playerId) && request.auth.uid == playerId;
      allow delete: if isSignedIn() && isExistingOwner(playerId) && request.auth.uid == playerId;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(playerId) {
      return request.auth.uid == playerId;
    }

   function isExistingOwner(playerId) {
      return isSignedIn() && isOwner(playerId) && resource != null;
    }
  }
}