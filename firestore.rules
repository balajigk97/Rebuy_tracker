/**
 * @fileOverview Firestore Security Rules for the poker game application.
 *
 * Core Philosophy:
 * This ruleset implements a permissive security posture focused on rapid prototyping while ensuring basic authorization.
 * Players can update their own rebuys, but all other data requires review for tighter restrictions.
 *
 * Data Structure:
 * The application stores player data under the `/players/{playerId}` collection.
 *
 * Key Security Decisions:
 *  - Players are not allowed to be listed publicly.
 *  - Players are allowed to update their own `rebuys` as required by the application, but all other fields should be restricted.
 *
 * Denormalization for Authorization:
 *  - None required at this time.
 *
 * Structural Segregation:
 *  - None required at this time.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages access to player data. Players can update their own rebuys.
     * @path /players/{playerId}
     * @allow (update) User with UID 'BKd0tuUHi1h2pR59Ys9Fwbk4VDA2' can update the `rebuys` field in their player document.
     * @deny (create) Any user cannot create a player document through direct write, it is likely handled via a function.
     * @deny (delete) Any user cannot delete a player document.
     * @deny (update) User with UID 'randomUID' cannot update the player document if they are not the owner.
     * @deny (update) User with UID 'BKd0tuUHi1h2pR59Ys9Fwbk4VDA2' cannot update fields other than rebuys.
     * @principle Enforces ownership and restricts field updates to `rebuys`.
     */
    match /players/{playerId} {
      // Helper function to check if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the document.
      function isOwner(playerId) {
        return isSignedIn() && request.auth.uid == playerId;
      }

      // Helper function to check if the user is the existing owner of the document
      function isExistingOwner(playerId) {
        return isOwner(playerId) && resource != null;
      }

      // Allow read access to individual player documents
      allow get: if true;

      // Prevent listing of all player documents.
      allow list: if false;

      // Only allow create if false
      allow create: if false;

      // Allow a player to update ONLY their rebuys field if they are the owner.
      allow update: if isExistingOwner(playerId) && request.resource.data.keys().toSet().hasOnly(['rebuys']) ;

      // Prevent deleting player documents
      allow delete: if false;
    }
  }
}