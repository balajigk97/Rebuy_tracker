/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a player-ownership model, where each player can only read and write their own data.
 *
 * Data Structure:
 * - /players/{playerId}: Stores player information. The {playerId} MUST match the authenticated user's UID.
 *
 * Key Security Decisions:
 * - Players can only manage their own player document.
 * - Data shape is not strictly enforced during the prototyping phase.
 * - No user listing is allowed.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages access to individual player documents.
     * @path /players/{playerId}
     * @allow (create) - A user can create their own player document if the {playerId} matches their UID.
     * @allow (get) - A user can read their own player document if the {playerId} matches their UID.
     * @allow (update) - A user can update their own player document if the {playerId} matches their UID and the document exists.
     * @allow (delete) - A user can delete their own player document if the {playerId} matches their UID and the document exists.
     * @deny (create) - A user cannot create a player document for another user (mismatched {playerId}).
     * @deny (get) - A user cannot read another user's player document (mismatched {playerId}).
     * @deny (update) - A user cannot update another user's player document (mismatched {playerId}).
     * @deny (delete) - A user cannot delete another user's player document (mismatched {playerId}).
     * @principle Enforces document ownership for writes.
     */
    match /players/{playerId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(playerId) {
        return request.auth.uid == playerId;
      }

      function isExistingOwner(playerId) {
        return isOwner(playerId) && exists(/databases/$(database)/documents/players/$(playerId));
      }

      allow get: if isSignedIn() && isOwner(playerId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(playerId);
      allow update: if isSignedIn() && isExistingOwner(playerId);
      allow delete: if isSignedIn() && isExistingOwner(playerId);
    }
  }
}