/**
 * @fileoverview Firestore Security Rules for the poker game application.
 *
 * Core Philosophy:
 * This ruleset prioritizes security for player data. It allows any logged-in user to read (get and list) player data, but restricts write operations to prevent unauthorized modification or deletion.
 *
 * Data Structure:
 * The application stores player data in a top-level `/players/{playerId}` collection.
 *
 * Key Security Decisions:
 * - Player listing is open to all authenticated users.
 * - Writes to player documents are forbidden.
 *
 * Rationale:
 * Given the error message "Missing or insufficient permissions" for a `list` operation on `/players`, the initial rules were likely too restrictive.
 * This update opens read access (get and list) to the `players` collection for all authenticated users. Write access remains denied to prevent unauthorized data manipulation.
 * If finer-grained access control is required in the future (e.g., allowing players to modify their own data), the rules will need to be updated with more specific logic.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants read access to player data for all authenticated users, but denies all write operations.
     * @path /players/{playerId}
     * @allow (get, list) An authenticated user can read player data.
     * @deny (create, update, delete) No user can create, update, or delete player data.
     * @principle Allows public read access while restricting all writes.
     */
    match /players/{playerId} {
      allow get, list: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // Helper function to check if the user is signed in.
    function isSignedIn() {
      return request.auth != null;
    }
  }
}