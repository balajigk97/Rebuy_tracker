/**
 * @fileoverview Firestore Security Rules for the poker game application.
 *
 * Core Philosophy:
 * This ruleset employs a user-ownership model. Each player document is considered owned
 * by the anonymous user who created it.
 *
 * Data Structure:
 * The Firestore database stores player data in the `/players/{playerId}` collection.
 *
 * Key Security Decisions:
 * - Players can only create, read, update, and delete their own player documents.
 * - Listing players is not allowed to prevent information disclosure.
 *
 * Denormalization for Authorization:
 *  - The playerId is the same as the auth.uid to make authorization simpler.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Defines whether a user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the current user is the owner of the given player ID.
     */
    function isOwner(playerId) {
      return isSignedIn() && request.auth.uid == playerId;
    }

    /**
     * @description Checks if the current user is the owner of the existing document.
     */
    function isExistingOwner(playerId) {
      return isOwner(playerId) && resource != null;
    }

    /**
     * @description Security rules for the /players/{playerId} collection.
     * @path /players/{playerId}
     * @allow (create) User with UID 'user123' creates a new player document with ID 'user123'.
     * @allow (get) User with UID 'user123' reads their own player document with ID 'user123'.
     * @allow (update) User with UID 'user123' updates their own player document with ID 'user123'.
     * @allow (delete) User with UID 'user123' deletes their own player document with ID 'user123'.
     * @deny (create) User with UID 'user456' tries to create a player document with ID 'user123'.
     * @deny (get) User with UID 'user456' tries to read player document with ID 'user123'.
     * @deny (update) User with UID 'user456' tries to update player document with ID 'user123'.
     * @deny (delete) User with UID 'user456' tries to delete player document with ID 'user123'.
     * @principle Enforces document ownership for all operations.
     */
    match /players/{playerId} {
      allow get: if isOwner(playerId);
      allow list: if false; // Listing all players is not permitted.
      allow create: if isOwner(playerId) && request.resource.data.keys().hasAll(['name', 'rebuys', 'blackCoins', 'createdAt']);
      allow update: if isExistingOwner(playerId);
      allow delete: if isExistingOwner(playerId);
    }
  }
}