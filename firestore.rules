/**
 * @fileOverview Firestore Security Rules for the poker game application.
 *
 * Core Philosophy:
 * This ruleset implements a basic access control model. Players can create their own player documents.
 *
 * Data Structure:
 * The primary data is stored in the `/players/{playerId}` collection.
 *
 * Key Security Decisions:
 *  - Players can only create their own player documents, where {playerId} matches their `request.auth.uid`.
 *  - Read access (get, list) to player documents is open to everyone since the game is public.
 *  - Updates and Deletes are forbidden.
 *
 * Denormalization for Authorization:
 *  - To simplify rules and avoid `get()` calls, the `playerId` from the path is used directly for authorization checks.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants read access to all players and allows authenticated users to create their own player document. Updates/Deletes are forbidden.
     * @path /players/{playerId}
     * @allow (create) User 'BKd0tuUHi1h2pR59Ys9Fwbk4VDA2' can create a player document at /players/BKd0tuUHi1h2pR59Ys9Fwbk4VDA2.
     * @deny (create) User 'BKd0tuUHi1h2pR59Ys9Fwbk4VDA2' cannot create a player document at /players/differentPlayerId.
     * @principle Allows self-creation of player documents and public read access.
     */
    match /players/{playerId} {
      allow get, list: if true;
      allow create: if isSignedIn() && isOwner(playerId);
      allow update, delete: if false;
    }

    // --- Helper functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
  }
}