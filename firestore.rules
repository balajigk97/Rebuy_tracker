/**
 * @fileoverview Firestore Security Rules for the poker game application.
 *
 * Core Philosophy:
 * This ruleset prioritizes simplicity and security in the initial prototyping phase.
 * It enforces a flexible data model and prioritizes authentication.
 *
 * Data Structure:
 * The database contains a top-level `/players/{playerId}` collection, where each document
 * stores the poker player's game data.
 *
 * Key Security Decisions:
 * - Data Access: Each player document is publicly readable, but only modifiable by the application.
 * - Authentication: Utilizes anonymous authentication. All authenticated users can read.
 * - Data Validation: During prototyping, data validation is kept to a minimum to enable
 *   rapid iteration. Only relationships critical for authorization are enforced.
 *
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages access control for individual player documents.
     * @path /players/{playerId}
     * @allow (get, list) Any signed-in user can read the player data.
     * @allow (create) Only the application can create player data, setting the current time.
     * @deny (update) Updates can only be performed by the application
     * @deny (delete) Deletions are not allowed.
     * @principle Allows public read access to player data but secures writes.
     */
    match /players/{playerId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}