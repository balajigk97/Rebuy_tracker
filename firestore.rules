/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for player data.
 *
 * Data Structure:
 * All player data is stored under the `/players/{playerId}` path.
 *
 * Key Security Decisions:
 * - Players can only read and write their own data.
 * - Listing of players is disallowed to protect user privacy.
 *
 * Denormalization for Authorization:
 * The `playerId` is used as the owner identifier, and is present both in the path and as the document ID,
 * allowing for simpler rules without needing to duplicate data inside the document.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages access control for player documents. Players can only create, read, update, and delete their own player documents.
     * @path /players/{playerId}
     * @allow (create) - Authenticated user creates a new player document with their own uid as the document ID.
     * @allow (get) - Authenticated user reads their own player document.
     * @allow (update) - Authenticated user updates their own player document.
     * @allow (delete) - Authenticated user deletes their own player document.
     * @deny (create) - Authenticated user tries to create a player document with an ID different from their own uid.
     * @deny (get) - Authenticated user tries to read another player's document.
     * @deny (update) - Authenticated user tries to update another player's document.
     * @deny (delete) - Authenticated user tries to delete another player's document.
     * @principle Enforces document ownership for all operations.
     */
    match /players/{playerId} {
      // Helper function to check if the requesting user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the requesting user owns the document
      function isOwner(playerId) {
        return isSignedIn() && request.auth.uid == playerId;
      }

      // Helper function to check if the requesting user owns the existing document
      function isExistingOwner(playerId) {
        return isOwner(playerId) && resource != null;
      }

      // Allow a user to read their own player document.
      allow get: if isOwner(playerId);

      // Prevent listing of all player documents.
      allow list: if false;

      // Allow a user to create their own player document, enforcing that the document ID matches their user ID.
      allow create: if isOwner(playerId);

      // Allow a user to update their own player document.
      allow update: if isExistingOwner(playerId);

      // Allow a user to delete their own player document.
      allow delete: if isExistingOwner(playerId);
    }
  }
}