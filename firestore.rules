/**
 * @fileoverview Firestore Security Rules for the Poker Game application.
 *
 * This ruleset secures a multi-table poker game application.
 * Data is structured with a top-level 'tables' collection, where each table
 * document can contain a 'players' subcollection.
 *
 * Key Security Decisions:
 * - Authenticated Access Only: All database operations (read, write, create, delete)
 *   require the user to be authenticated via Firebase Authentication (including anonymous).
 *   This ensures that only users running the application can interact with the game data.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /tables/{tableId} {
      // Allow signed-in users to read and write tables.
      allow read, write: if request.auth != null;

      // Rules for the 'players' subcollection within each table.
      match /players/{playerId} {
        // Allow signed-in users to read and write player data.
        allow read, write: if request.auth != null;
      }
    }
  }
}
