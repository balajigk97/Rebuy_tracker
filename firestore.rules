/**
 * @description This ruleset enforces a public read, owner-write model for player data.
 * @dataStructure The database stores player information under the `/players/{playerId}` path.
 * @keySecurityDecisions
 *   - Players can be listed by anyone
 *   - Players can be created, updated and deleted by only authenticated users.
 *   - No schema validation is done for prototyping speed.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows anyone to read player data, but only authenticated users can create, update or delete it.
     * @path /players/{playerId}
     * @allow (get, list): Allows anyone to read player documents.
     * @allow (create): Only authenticated users can create player documents.
     * @allow (update, delete): Only authenticated users can update or delete player documents.
     * @deny (create): If the authenticated user ID does not match the player document's owner ID.
     * @deny (update, delete): If the authenticated user is not the owner of the player document.
     * @principle Allows public read access while restricting write access to authenticated users.
     */
    match /players/{playerId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    // Define helper functions here
    function isSignedIn() {
      return request.auth != null;
    }
  }
}