/**
 * @fileoverview Firestore Security Rules for Rebuy Tracker.
 *
 * Core Philosophy:
 * This ruleset enforces a role-based access control model. Only authenticated
 * users with the designated "dealer" role have write access to the "Dealers" collection.
 * All read access to the Dealers collection is denied to unauthorized users.
 * All users can read the public 'Players' collection.
 *
 * Data Structure:
 * - /Dealers/{dealerId}: Stores dealer-specific data. Only dealers can modify.
 * - /Players/{playerId}: Stores player data. Publicly readable, but only authorized
 * users (dealers) can modify.
 *
 * Key Security Decisions:
 * - User listing is disabled to prevent enumeration.
 * - Default security posture is strict; any access not explicitly allowed is denied.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secure the 'Dealers' collection. Only authenticated users can access.
     * @path /Dealers/{dealerId}
     * @allow (create) User with 'dealer' role can create a dealer profile.
     * @deny (create) User without 'dealer' role cannot create a dealer profile.
     * @allow (get, list) Authenticated user can read any dealer profile.
     * @deny (update, delete) Only the dealer themselves can update/delete their profile.
     * @principle Enforces role-based access control for dealer data.
     */
    match /Dealers/{dealerId} {
      allow get, list: if false;
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    /**
     * @description Secure the 'Players' collection.
     * @path /Players/{playerId}
     * @allow (get, list) Any user can read player data.
     * @deny (create, update, delete) Only authenticated admins can modify player data.
     * @principle Public read access with restricted writes.
     */
    match /Players/{playerId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
          && get(/databases/$(database)/documents/Dealers/$(request.auth.uid)).data.role == 'dealer';
    }
  }
}