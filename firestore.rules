/**
 * @fileoverview Firestore Security Rules for the poker game application.
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model where each player document is owned by the anonymous user who created it.
 *
 * Data Structure:
 * All player data is stored in the `/players/{playerId}` collection.
 *
 * Key Security Decisions:
 * - Players can only create, read, update, or delete their own player document.
 * - Listing of players is disallowed for privacy reasons.
 *
 * Denormalization for Authorization:
 * - The player ID is used as the document ID, enforcing a one-to-one relationship between the anonymous user and the player document. This allows direct ownership checks without additional reads.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages access to player documents.
     * @path /players/{playerId}
     * @allow (create) User with UID 'user_abc' can create a player document if playerId == user_abc.
     * @deny (create) User with UID 'user_abc' cannot create a player document if playerId != user_abc.
     * @allow (get) User with UID 'user_abc' can read player document if playerId == user_abc.
     * @deny (get) User with UID 'user_def' cannot read player document if playerId == user_abc.
     * @allow (update) User with UID 'user_abc' can update player document if playerId == user_abc.
     * @deny (update) User with UID 'user_def' cannot update player document if playerId == user_abc.
     * @allow (delete) User with UID 'user_abc' can delete player document if playerId == user_abc.
     * @deny (delete) User with UID 'user_def' cannot delete player document if playerId == user_abc.
     * @principle Enforces document ownership for writes.
     */
    match /players/{playerId} {
      allow get: if isSignedIn() && isOwner(playerId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(playerId);
      allow update: if isSignedIn() && isExistingOwner(playerId);
      allow delete: if isSignedIn() && isExistingOwner(playerId);
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isSignedIn() && isOwner(userId) && resource != null;
    }
  }
}