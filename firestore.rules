/**
 * @fileoverview Firestore Security Rules for the poker game application.
 *
 * Core Philosophy:
 * This ruleset prioritizes security for player data. It allows any authenticated user to list player documents but requires authentication for creating, updating, or deleting player data.  Since we do not have any concept of ownership or user id, all authenticated users can modify all the data. This should be changed for production.
 *
 * Data Structure:
 * - /players/{playerId}: Stores player information.
 *
 * Key Security Decisions:
 * - Player documents are publicly listable to all authenticated users.
 * - All authenticated users can create, update, and delete player data. This should be restricted in the future, likely to a concept of ownership or game admin roles.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Rules for the /players/{playerId} collection. Allows listing for all authenticated users, and create/update/delete for all authenticated users.
     * @path /players/{playerId}
     * @allow (list) User is authenticated.
     * @allow (create) User is authenticated.
     * @allow (update) User is authenticated.
     * @allow (delete) User is authenticated.
     * @deny (create) User is not authenticated.
     * @deny (update) User is not authenticated.
     * @deny (delete) User is not authenticated.
     * @principle Allows all authenticated users to list players and create/update/delete player data.
     */
    match /players/{playerId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    // Helper function to check if the user is signed in.
    function isSignedIn() {
      return request.auth != null;
    }
  }
}