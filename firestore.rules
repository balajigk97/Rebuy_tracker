/**
 * @description This ruleset enforces a strict owner-only access model for player data. Players can only read and write their own player documents.
 * @dataStructure The data is stored in the `/players/{playerId}` collection, where `{playerId}` is the unique ID of the player.
 * @keySecurityDecisions
 *   - Players can only create, read, update, and delete their own player documents.
 *   - Listing the `players` collection is denied to all users.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to individual player documents.
     * @path /players/{playerId}
     * @allow (create) A player with UID "user_abc" can create their player document at /players/user_abc.
     * @allow (get) A player with UID "user_abc" can read their player document at /players/user_abc.
     * @allow (update) A player with UID "user_abc" can update their player document at /players/user_abc.
     * @allow (delete) A player with UID "user_abc" can delete their player document at /players/user_abc.
     * @deny (create) A player with UID "user_abc" cannot create a player document at /players/user_xyz.
     * @deny (get) A player with UID "user_abc" cannot read a player document at /players/user_xyz.
     * @deny (update) A player with UID "user_abc" cannot update a player document at /players/user_xyz.
     * @deny (delete) A player with UID "user_abc" cannot delete a player document at /players/user_xyz.
     * @principle Enforces document ownership for all operations.
     */
    match /players/{playerId} {
      // Helper function to check if the current user is the owner of the document.
      function isOwner(playerId) {
        return request.auth != null && request.auth.uid == playerId;
      }

      // Helper function to check if the document exists and the current user is the owner.
      function isExistingOwner(playerId) {
        return isOwner(playerId) && resource != null;
      }

      // Allow players to read their own player documents.
      allow get: if isOwner(playerId);

      // Deny listing of player documents to all users.
      allow list: if false;

      // Allow players to create their own player documents, enforcing that the document ID matches the user ID.
      allow create: if isOwner(playerId) && request.resource.data.keys().hasAll(['name','blackCoins','createdAt','rebuyTimestamps','hasPendingRebuyRequest']);

      // Allow players to update their own player documents if it exists.
      allow update: if isExistingOwner(playerId);

      // Allow players to delete their own player documents if it exists.
      allow delete: if isExistingOwner(playerId);
    }
  }
}