/**
 * @file Firestore Security Rules for the Poker Game application.
 *
 * @core_philosophy This ruleset enforces a user-ownership model for player data.
 *  Each player can only read and write their own data.
 *
 * @data_structure All player data is stored under the `/players/{playerId}` path.
 *
 * @key_security_decisions
 *  - Players can only manage their own player document.
 *  - No user listing is allowed.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages access to player data, enforcing player-ownership.
     * @path /players/{playerId}
     * @allow (create) - A player can create their own document if their auth UID matches the playerId.
     * @allow (get, update, delete) - A player can read, update, and delete their own document.
     * @deny (create) - A player cannot create a document with an ID that does not match their auth UID.
     * @deny (get, update, delete) - A player cannot read, update, or delete another player's document.
     * @principle Enforces document ownership for all operations on player data.
     */
    match /players/{playerId} {
      // Helper function to check if the user is signed in.
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the document.
      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      // Helper function to check if the user is the owner of the existing document.
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      // Allow a player to create their own document.
      allow create: if isOwner(playerId);

      // Allow a player to read their own document.
      allow get: if isOwner(playerId);

      // Allow a player to list (query) their own document - typically not used in this scenario.
      allow list: if false;

      // Allow a player to update their own document.
      allow update: if isExistingOwner(playerId);

      // Allow a player to delete their own document.
      allow delete: if isExistingOwner(playerId);
    }
  }
}