/**
 * @fileoverview Firestore Security Rules for the Poker Game application.
 *
 * Core Philosophy:
 * This ruleset prioritizes simplicity, security and data access control by leveraging the Firebase Authentication state (`request.auth`).
 * It focuses on securing read and write access to a public collection of `players`. All users, including unauthenticated ones, can read `players` collection, but only authenticated users can create, update or delete player information.
 *
 * Data Structure:
 * The Firestore database contains two top-level collections:
 * - `/players/{playerId}`: Stores individual player profiles for the live game.
 * - `/games/{gameId}`: Stores historical records of completed games.
 *
 * Key Security Decisions:
 * - Public Read Access: All users, including unauthenticated users, can read all documents in the `players` and `games` collections.
 * - Authenticated Writes: Only authenticated users can create, update, and delete documents.
 *
 * Denormalization for Authorization:
 * - The `Player` documents are assumed to contain all the necessary information for authorization.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows anyone to read player data, but only authenticated users to write.
     * @path /players/{playerId}
     * @allow (get, list): Anyone can read player data.
     * @allow (create): Authenticated user can create a player if the player data is valid.
     * @allow (update, delete): Authenticated user can update/delete player data if the player data is valid.
     * @deny (create, update, delete): Unauthenticated user cannot create/update/delete player data.
     * @principle Allows public read access to player data and authenticated writes.
     */
    match /players/{playerId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    /**
     * @description Allows anyone to read game history, but only authenticated users to write.
     * @path /games/{gameId}
     * @allow (get, list): Anyone can read game history.
     * @allow (create): Authenticated users can create new game history records.
     * @principle Allows public read access to game history and authenticated writes for archival.
     */
    match /games/{gameId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if false; // Game history should be immutable.
    }

    // ---- Helper functions ----

    /**
     * @description Checks if the user is signed in.
     * @return {bool} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }
  }
}
