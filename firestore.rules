/**
 * @file Firestore Security Rules
 * @core_philosophy This ruleset enforces a user-ownership model for user profiles
 * and allows dealers (authenticated users) to manage player information. It prioritizes
 * security by default, restricting access where it is not explicitly granted.
 * @data_structure
 *   - /users/{userId}: Stores user profile information. Access is restricted to the
 *     authenticated user with a matching userId.
 *   - /players/{playerId}: Stores player information. Accessible by any authenticated dealer.
 * @key_security_decisions
 *   - User listing is disallowed to protect user privacy.
 *   - Player data is accessible by any authenticated dealer.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     * @allow (get) User 'user_abc' can read their own profile.
     *   - request.auth.uid: 'user_abc'
     *   - userId: 'user_abc'
     * @allow (create) User 'user_abc' can create their own profile.
     *   - request.auth.uid: 'user_abc'
     *   - userId: 'user_abc'
     * @allow (update) User 'user_abc' can update their own profile.
     *   - request.auth.uid: 'user_abc'
     *   - userId: 'user_abc'
     * @allow (delete) User 'user_abc' can delete their own profile.
     *   - request.auth.uid: 'user_abc'
     *   - userId: 'user_abc'
     * @deny (get) User 'user_xyz' cannot read user 'user_abc' profile.
     *   - request.auth.uid: 'user_xyz'
     *   - userId: 'user_abc'
     * @deny (create) User 'user_xyz' cannot create user 'user_abc' profile.
     *   - request.auth.uid: 'user_xyz'
     *   - userId: 'user_abc'
     * @deny (update) User 'user_xyz' cannot update user 'user_abc' profile.
     *   - request.auth.uid: 'user_xyz'
     *   - userId: 'user_abc'
     * @deny (delete) User 'user_xyz' cannot delete user 'user_abc' profile.
     *   - request.auth.uid: 'user_xyz'
     *   - userId: 'user_abc'
     * @principle Enforces user-ownership for profile data.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.uid == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.uid == resource.data.uid;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to player documents.  Dealers can create, read, update, and delete player information.
     * @path /players/{playerId}
     * @allow (get) Any authenticated user can read player data.
     *   - request.auth.uid: 'any_user'
     * @allow (list) Any authenticated user can list player data.
     *   - request.auth.uid: 'any_user'
     * @allow (create) Any authenticated user can create player data.
     *   - request.auth.uid: 'any_user'
     * @allow (update) Any authenticated user can update player data.
     *   - request.auth.uid: 'any_user'
     * @allow (delete) Any authenticated user can delete player data.
     *   - request.auth.uid: 'any_user'
     * @principle Allows dealers to manage player information.
     */
    match /players/{playerId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }
  }
}