/**
 * @fileoverview Firestore Security Rules for Prototyping.
 *
 * Core Philosophy:
 * This ruleset is in prototyping mode and prioritizes developer velocity.  It enforces basic authentication and access control.
 *
 * Data Structure:
 * All data is stored in a flat `/players/{playerId}` collection.
 *
 * Key Security Decisions:
 * - Anonymous authentication is enabled.
 * - Players can only create their own player document, after which only they can read or modify it.
 * - Data validation is relaxed for prototyping speed, but ownership is strictly enforced.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants player read and write access to their own player document.
     * @path /players/{playerId}
     * @allow (create) User 'BKd0tuUHi1h2pR59Ys9Fwbk4VDA2' can create a player document with playerId 'BKd0tuUHi1h2pR59Ys9Fwbk4VDA2'.
     * @allow (get) User 'BKd0tuUHi1h2pR59Ys9Fwbk4VDA2' can read a player document with playerId 'BKd0tuUHi1h2pR59Ys9Fwbk4VDA2'.
     * @allow (update) User 'BKd0tuUHi1h2pR59Ys9Fwbk4VDA2' can update a player document with playerId 'BKd0tuUHi1h2pR59Ys9Fwbk4VDA2'.
     * @allow (delete) User 'BKd0tuUHi1h2pR59Ys9Fwbk4VDA2' can delete a player document with playerId 'BKd0tuUHi1h2pR59Ys9Fwbk4VDA2'.
     * @deny (create) User 'someOtherUserId' cannot create a player document with playerId 'BKd0tuUHi1h2pR59Ys9Fwbk4VDA2'.
     * @deny (get) User 'someOtherUserId' cannot read a player document with playerId 'BKd0tuUHi1h2pR59Ys9Fwbk4VDA2'.
     * @deny (update) User 'someOtherUserId' cannot update a player document with playerId 'BKd0tuUHi1h2pR59Ys9Fwbk4VDA2'.
     * @deny (delete) User 'someOtherUserId' cannot delete a player document with playerId 'BKd0tuUHi1h2pR59Ys9Fwbk4VDA2'.
     * @principle Enforces document ownership for writes, restricts access to a user's own data tree.
     */
    match /players/{playerId} {
      allow get: if isSignedIn() && isOwner(playerId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(playerId);
      allow update: if isSignedIn() && isOwner(playerId) && resource != null;
      allow delete: if isSignedIn() && isExistingOwner(playerId);
    }

    // --- Helper functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }
  }
}